{
  "customSyntax": "postcss-scss",
  "plugins": ["stylelint-order"],
  "rules": {
    "order/properties-order": [
      [
        {
          "groupName": "псевдо элементы",
          "emptyLineBefore": "never",
          "emptyLineBetween": "always",
          "properties": ["content"]
        },
        {
          "groupName": "Позиционирование",
          "emptyLineBefore": "always",
          "emptyLineBetween": "never",
          "properties": [
            "position",
            "inset",
            "top",
            "right",
            "bottom",
            "left",
            "z-index"
          ]
        },
        {
          "groupName": "Блочная модель",
          "emptyLineBefore": "always",
          "emptyLineBetween": "never",
          "properties": [
            "display",
            "float",
            "clear",
            "width",
            "height",
            "max-width",
            "max-height",
            "min-width",
            "min-height",
            "margin",
            "margin-top",
            "margin-right",
            "margin-bottom",
            "margin-left",
            "padding",
            "padding-top",
            "padding-right",
            "padding-bottom",
            "padding-left",
            "overflow",
            "overflow-x",
            "overflow-y",
            "box-sizing",
            "gap",
            "row-gap",
            "column-gap",
            "flex",
            "flex-basis",
            "flex-direction",
            "flex-grow",
            "flex-shrink",
            "flex-wrap",
            "justify-content",
            "align-items",
            "align-content",
            "place-items",
            "order"
          ]
        },
        {
          "groupName": "Типографика",
          "emptyLineBefore": "always",
          "emptyLineBetween": "never",
          "properties": [
            "font",
            "font-family",
            "font-style",
            "font-size",
            "font-weight",
            "font-variant",
            "line-height",
            "letter-spacing",
            "word-spacing",
            "text-align",
            "text-align-last",
            "text-transform",
            "text-decoration",
            "text-decoration-color",
            "text-decoration-style",
            "text-decoration-line",
            "text-shadow",
            "text-indent",
            "text-overflow",
            "white-space",
            "word-break",
            "word-wrap",
            "overflow-wrap",
            "color",
            "vertical-align"
          ]
        },
        {
          "groupName": "Оформление",
          "emptyLineBefore": "always",
          "emptyLineBetween": "never",
          "properties": [
            "background",
            "background-color",
            "background-image",
            "background-repeat",
            "background-position",
            "background-size",
            "background-attachment",
            "background-clip",
            "border",
            "border-top",
            "border-right",
            "border-bottom",
            "border-left",
            "border-width",
            "border-style",
            "border-color",
            "border-top-width",
            "border-top-style",
            "border-top-color",
            "border-right-width",
            "border-right-style",
            "border-right-color",
            "border-bottom-width",
            "border-bottom-style",
            "border-bottom-color",
            "border-left-width",
            "border-left-style",
            "border-left-color",
            "border-radius",
            "border-top-left-radius",
            "border-top-right-radius",
            "border-bottom-right-radius",
            "border-bottom-left-radius",
            "box-shadow",
            "list-style",
            "opacity",
            "outline",
            "outline-color",
            "outline-style",
            "outline-width",
            "outline-offset",
            "filter"
          ]
        },
        {
          "groupName": "Анимация",
          "emptyLineBefore": "always",
          "emptyLineBetween": "never",
          "properties": [
            "transition",
            "transition-property",
            "transition-duration",
            "transition-timing-function",
            "transition-delay",
            "animation",
            "animation-name",
            "animation-duration",
            "animation-timing-function",
            "animation-delay",
            "animation-iteration-count",
            "animation-direction",
            "animation-fill-mode",
            "animation-play-state",
            "transform",
            "transform-origin",
            "transform-style",
            "perspective",
            "perspective-origin",
            "backface-visibility"
          ]
        },
        {
          "groupName": "Разное",
          "emptyLineBefore": "always",
          "emptyLineBetween": "never",
          "properties": [
            "cursor",
            "pointer-events",
            "user-select",
            "user-drag",
            "visibility",
            "will-change",
            "clip",
            "clip-path",
            "resize",
            "tab-size",
            "scroll-behavior",
            "scroll-snap-type",
            "scroll-snap-align"
          ]
        }
      ],
      {
        "unspecified": "bottomAlphabetical"
      }
    ]
  }
}
